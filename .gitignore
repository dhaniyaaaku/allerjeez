# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/

# Environment / secrets — NEVER commit these
.env
.env.local
*.env

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Test / coverage artifacts
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Local data (we don't want to commit large data files)
data/raw/
data/processed/
*.sqlite
*.db

# Eval runner cache (per-entry results, regenerated by run_eval.py)
eval/.cache_results.jsonl

# Streamlit local state
.streamlit/secrets.toml
